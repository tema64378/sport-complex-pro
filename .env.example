# Frontend
VITE_API_BASE=/api
VITE_CLOUDPAYMENTS_PUBLIC_ID=your_public_id
VITE_VK_APP_ID=your_vk_app_id

# Backend (Rust + SQLite, local only)
PORT=4000
RUST_DB_PATH=./data.db
RUST_BACKUP_DIR=./backups
RUST_BACKUP_KEEP=14

# Optional payment credentials for test integrations
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
TINKOFF_TERMINAL_KEY=your_terminal_key
TINKOFF_PASSWORD=your_terminal_password
TINKOFF_API_TOKEN=your_api_token

# VK OAuth
VK_CLIENT_ID=your_vk_app_id
VK_CLIENT_SECRET=your_vk_client_secret
VK_REDIRECT_URI=http://localhost:4000/api/auth/vk/callback
