{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Frontend (Vite) on localhost:3000",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Backend-served site on localhost:4000",
      "url": "http://localhost:4000",
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Open Both (frontend + backend)",
      "configurations": [
        "Launch Frontend (Vite) on localhost:3000",
        "Launch Backend-served site on localhost:4000"
      ]
    }
  ]
}