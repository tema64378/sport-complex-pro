flowchart TD
    A([Старт]) --> B[Ввести email и пароль]
    B --> C{Поля заполнены?}
    C -- Нет --> D[Показать ошибку валидации]
    D --> B
    C -- Да --> E[POST /api/auth/login]
    E --> F{Код ответа 200?}
    F -- Нет --> G[Показать сообщение\nНеверные данные]
    G --> B
    F -- Да --> H[Сохранить auth_token и профиль]
    H --> I([Конец: пользователь авторизован])
